# ─── Deployment wallet ────────────────────────────────────────────────────────
# Private key of the wallet paying deployment gas (keep this secret, never commit)
DEPLOYER_PRIVATE_KEY=0x...

# ─── Protocol roles ───────────────────────────────────────────────────────────
# Address granted DEFAULT_ADMIN_ROLE, AGENT_MANAGER_ROLE, FEE_MANAGER_ROLE
ADMIN_ADDRESS=0x...

# Public address of the agent-node signing wallet (from agent-node .env)
AGENT_SIGNER_ADDRESS=0x...

# Address that collects protocol fees on each contractor withdrawal
FEE_RECIPIENT_ADDRESS=0x...

# Initial fee in basis points — 50 = 0.5%, max 500 = 5%
FEE_BPS=50

# ─── Verification ─────────────────────────────────────────────────────────────
# Arbiscan API key — get one free at https://arbiscan.io/myapikey
ETHERSCAN_API_KEY=...

# ─── Robinhood Chain Testnet ──────────────────────────────────────────────────
# Chain ID: 46630 | Block explorer: explorer.testnet.chain.robinhood.com
# Public RPC (rate-limited):
ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com
# Recommended — Alchemy (faster, get key at alchemy.com):
# ROBINHOOD_RPC_URL=https://robinhood-testnet.g.alchemy.com/v2/<YOUR_API_KEY>
